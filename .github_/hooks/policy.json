{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/post_tool_artifact_guard.mjs",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .github/hooks/scripts/validate_guideline_output.mjs",
        "timeout": 20
      }
    ]
  }
}
